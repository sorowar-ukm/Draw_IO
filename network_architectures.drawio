    <mxCell id="p2_qc_container" value="QuantumConv — PennyLane (lightning.qubit, 4 qubits)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f0ff;strokeColor=#9673a6;strokeWidth=2;dashed=1;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="80" y="2230" width="500" height="220" as="geometry"/>
    </mxCell>

    <mxCell id="p2_tanh" value="tanh activation on patch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="100" y="2270" width="180" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="p2_ry_in" value="&lt;b&gt;RY(input)&lt;/b&gt;&lt;br&gt;Encodes patch pixel → qubit rotation&lt;br&gt;4 qubits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="100" y="2330" width="180" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="p2_ry_w" value="&lt;b&gt;RY(weight)&lt;/b&gt;&lt;br&gt;Trainable rotation per qubit&lt;br&gt;4 qubits × N_Q_LAYERS = 12 params" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="310" y="2330" width="240" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="p2_cnot" value="&lt;b&gt;CNOT ring entanglement&lt;/b&gt;&lt;br&gt;q0→q1→q2→q3→q0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="100" y="2410" width="200" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="p2_measure" value="&lt;b&gt;Measure&lt;/b&gt;&lt;br&gt;⟨PauliZ⟩ × 4 + ⟨PauliX⟩ × 4 + ⟨PauliY⟩ × 4&lt;br&gt;= 12 expectation values per patch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="310" y="2410" width="240" height="65" as="geometry"/>
    </mxCell>

    <!-- Mean Pool Quantum output -->
    <mxCell id="p2_qmeanpool" value="&lt;b&gt;Mean Pool&lt;/b&gt;&lt;br&gt;Spatial mean over patches&lt;br&gt;→ 12-dim vector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="200" y="2490" width="200" height="65" as="geometry"/>
    </mxCell>

    <!-- Concatenation -->
    <mxCell id="p2_concat" value="&lt;b&gt;Concatenate&lt;/b&gt;&lt;br&gt;[64-dim || 12-dim]&lt;br&gt;→ 76-dim vector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="500" y="2490" width="180" height="65" as="geometry"/>
    </mxCell>

    <!-- FC Classifier -->
    <mxCell id="p2_fc_cls" value="&lt;b&gt;FC Classifier&lt;/b&gt;&lt;br&gt;Linear 76 → 64&lt;br&gt;ReLU + Dropout(0.3)&lt;br&gt;Linear 64 → 2 (NUM_CLASSES)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="470" y="2610" width="220" height="90" as="geometry"/>
    </mxCell>

    <!-- Output Net2 -->
    <mxCell id="p2_output" value="&lt;b&gt;Output Logits&lt;/b&gt;&lt;br&gt;2-class (binary)&lt;br&gt;Class 0 vs Class 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="490" y="2760" width="180" height="65" as="geometry"/>
    </mxCell>

    <!-- ARROWS Net2 -->
    <mxCell id="e2_in_cfe" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_input" target="p2_block1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_x2_reduce" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_block2" target="p2_reduce" parent="1">
      <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="400" y="2085"/><mxPoint x="200" y="2085"/></Array></mxGeometry>
    </mxCell>
    <mxCell id="e2_x4_gap" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_block4" target="p2_gap" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_reduce_qc" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_reduce" target="p2_tanh" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_tanh_ry" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_tanh" target="p2_ry_in" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_ry_ryw" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_ry_in" target="p2_ry_w" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_ryw_cnot" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_ry_w" target="p2_cnot" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_cnot_meas" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_cnot" target="p2_measure" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_meas_pool" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_measure" target="p2_qmeanpool" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_pool_cat" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_qmeanpool" target="p2_concat" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_gap_cat" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_gap" target="p2_concat" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_cat_fc" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_concat" target="p2_fc_cls" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2_fc_out" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2_fc_cls" target="p2_output" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

